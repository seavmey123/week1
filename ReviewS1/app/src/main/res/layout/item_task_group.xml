<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Icon Container -->
        <androidx.cardview.widget.CardView
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            android:id="@+id/cvIconContainer">

            <ImageView
                android:id="@+id/ivGroupIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/offic_ic"
                android:padding="12dp"
                android:contentDescription="Group Icon"/>
        </androidx.cardview.widget.CardView>

        <!-- Group Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvGroupName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Office Project"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/tvTaskCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25 Tasks"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Progress Indicator -->
        <RelativeLayout
            android:layout_width="60dp"
            android:layout_height="60dp">

            <ProgressBar
                android:id="@+id/progressCircularGroup"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:progress="70"
                android:max="100"
                android:indeterminate="false"
                android:progressDrawable="@drawable/circular_progress_small"
                android:layout_centerInParent="true"/>

            <TextView
                android:id="@+id/tvGroupProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="70%"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/purple_500"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>